# Backend API origin (port must match uvicorn, default 8000). Paths use VITE_API_PREFIX below.
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_PREFIX=/api/v1
# true = online pharmacy/checkout off (call-to-order screen); false = full online store
VITE_PROD_CHECK=false

# Optional: lock customer/checkout city, state, PIN, country (single service area). Omit to leave editable from API/admin delivery_location only.
# VITE_DELIVERY_CITY=
# VITE_DELIVERY_STATE=
# VITE_DELIVERY_PINCODE=
# VITE_DELIVERY_COUNTRY=