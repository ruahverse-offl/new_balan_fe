# ============================================
# Frontend Environment (Vite)
# ============================================
# Copy to .env and adjust. Vite only exposes variables prefixed with VITE_
# Rebuild after changing (npm run build).

# --------------------------------------------
# Local development
# --------------------------------------------
# API base URL = backend origin, no trailing slash. No /api/v1 here (added by VITE_API_PREFIX).
VITE_API_BASE_URL=http://localhost:8000
VITE_API_PREFIX=/api/v1

# --------------------------------------------
# Deployment (Hostinger VPS)
# --------------------------------------------
# Hostinger VPS: Nginx reverse proxy terminates SSL (HTTPS). Backend receives HTTP internally.
# The browser must use the SAME scheme as the page (HTTPS) so API calls are same-origin (no mixed content).
#
# If your site is served over HTTPS:
#   VITE_API_BASE_URL=https://yourdomain.com
#   VITE_API_PREFIX=/api/v1
#
# If the VPS has no SSL and uses HTTP only:
#   VITE_API_BASE_URL=http://your-domain-or-ip
#
# Build for production, e.g.:
#   VITE_API_BASE_URL=https://yourdomain.com npm run build
# --------------------------------------------

# When true: pharmacy and checkout are enabled. When false: pharmacy shows "coming soon", checkout disabled.
VITE_PROD_CHECK=true
