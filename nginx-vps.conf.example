events {}

http {

  server {
      listen 80;
      server_name newbalanpharmacy.com api.newbalanpharmacy.com;
      return 301 https://$host$request_uri;
  }

  server {
      listen 443 ssl;
      server_name newbalanpharmacy.com;

      ssl_certificate /etc/letsencrypt/live/newbalanpharmacy.com/fullchain.pem;
      ssl_certificate_key /etc/letsencrypt/live/newbalanpharmacy.com/privkey.pem;

      location / {
          proxy_pass http://newbalan-frontend:4173;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
          proxy_set_header X-Forwarded-Proto $scheme;
      }
  }

  server {
      listen 443 ssl;
      server_name api.newbalanpharmacy.com;

      # Use a cert that INCLUDES api.newbalanpharmacy.com (fixes ERR_CERT_COMMON_NAME_INVALID)
      # Option A: separate cert for api subdomain (run: certbot certonly -d api.newbalanpharmacy.com ...)
      ssl_certificate /etc/letsencrypt/live/api.newbalanpharmacy.com/fullchain.pem;
      ssl_certificate_key /etc/letsencrypt/live/api.newbalanpharmacy.com/privkey.pem;
      # Option B: same cert for both (run: certbot certonly -d newbalanpharmacy.com -d api.newbalanpharmacy.com ...)
      # ssl_certificate /etc/letsencrypt/live/newbalanpharmacy.com/fullchain.pem;
      # ssl_certificate_key /etc/letsencrypt/live/newbalanpharmacy.com/privkey.pem;

      location / {
          proxy_pass http://newbalan-backend:8000;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
          proxy_set_header X-Forwarded-Proto $scheme;
      }
  }
}
